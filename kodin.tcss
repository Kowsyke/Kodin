/* Kodin - kodin.tcss
   Dark hacker aesthetic. All sizing is explicit so nothing collapses. */

/* ---- Screen / root ---- */
Screen {
    background: #0a0e14;
    layers: base;
}

/* ---- Root horizontal split ---- */
#root-split {
    layout: horizontal;
    width: 100%;
    height: 100%;
    background: #0a0e14;
}

/* ---- Sidebar ---- */
#sidebar {
    width: 28;
    height: 100%;
    background: #080c10;
    border-right: tall #1e2a38;
}

.panel-header {
    width: 100%;
    height: 1;
    background: #080c10;
    color: #00d4ff;
    text-style: bold;
    padding: 0 1;
}

DirectoryTree {
    width: 100%;
    height: 1fr;
    background: #080c10;
    color: #586069;
    scrollbar-background: #080c10;
    scrollbar-color: #1e2a38;
}

DirectoryTree > .directory-tree--folder {
    color: #c9d1d9;
}

DirectoryTree > .directory-tree--file {
    color: #586069;
}

DirectoryTree:focus .highlighted {
    background: #007a94;
    color: #c9d1d9;
}

/* ---- Main content column ---- */
#main-content {
    layout: vertical;
    width: 1fr;
    height: 100%;
    background: #0a0e14;
}

/* ---- Editor row (editor + claude side by side) ---- */
#editor-row {
    layout: horizontal;
    width: 100%;
    height: 1fr;
    background: #0a0e14;
}

/* ---- Editor widget ---- */
#editor {
    width: 1fr;
    height: 100%;
    background: #0a0e14;
    color: #c9d1d9;
    scrollbar-background: #0a0e14;
    scrollbar-color: #1e2a38;
}

/* ---- Claude panel ---- */
#claude-panel {
    width: 40;
    height: 100%;
    background: #0d1117;
    border-left: tall #1e2a38;
    display: none;
}

.claude-header {
    width: 100%;
    height: 1;
    background: #080c10;
    color: #a371f7;
    text-style: bold;
    padding: 0 1;
}

#claude-log {
    width: 100%;
    height: 1fr;
    background: #0d1117;
    color: #c9d1d9;
    scrollbar-background: #0d1117;
    scrollbar-color: #1e2a38;
}

#claude-input {
    width: 100%;
    height: 3;
    background: #080c10;
    color: #c9d1d9;
    border: tall #007a94;
}

#claude-input:focus {
    border: tall #00d4ff;
}

#claude-clear {
    width: 100%;
    height: 1;
    background: #1e2a38;
    color: #586069;
    border: none;
    text-style: none;
}

#claude-clear:hover {
    background: #1e2a38;
    color: #c9d1d9;
}

ClaudePanel Button {
    height: 1;
    min-width: 7;
    background: #080c10;
    color: #586069;
    border: none;
}

/* ---- Terminal panel ---- */
#terminal-panel {
    width: 100%;
    height: 12;
    background: #050810;
    border-top: tall #1e2a38;
    display: none;
}

.terminal-header {
    width: 100%;
    height: 1;
    background: #050810;
    color: #00d4ff;
    text-style: bold;
    padding: 0 1;
}

#term-log {
    width: 100%;
    height: 1fr;
    background: #050810;
    color: #39d353;
    scrollbar-background: #050810;
    scrollbar-color: #1e2a38;
}

/* ---- Status bar ---- */
#status-bar {
    width: 100%;
    height: 1;
    background: #007a94;
    color: #0a0e14;
}
